dist/
build/

# Config con datos sensibles
config.json

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Logs y datos temporales
*.log
*.tmp
.cache/

# Debug por corrida (artefactos grandes)
data/debug_runs/

# Public datasets: version docs/scripts/small metadata only.
# Keep local raw data out of git (reconstructable via scripts).
data/public_datasets/**/*.csv
data/public_datasets/**/*.zip
data/public_datasets/**/*.parquet
data/public_datasets/**/*.xlsx
data/public_datasets/**/*.feather
data/public_datasets/**/*.gz

# Desktop local ingest payloads (keep manifests/index docs only)
data/datasets/desktop_ingest_*/**/*.csv
data/datasets/desktop_ingest_*/**/*.zip
data/datasets/desktop_ingest_*/**/*.pdf
data/datasets/desktop_ingest_*/**/*.docx

# Knowledge refresh / Dojo candidates (generados en runtime; mantener .gitkeep)
data/dojo/training_candidates/*.json
data/knowledge/refresh/knowledge_refresh_runs.jsonl
data/knowledge/refresh/observed_queue.jsonl
data/knowledge/refresh/accepted_knowledge.jsonl
data/knowledge/refresh/refresh_state.json
data/knowledge/refresh/latest_refresh_summary.json
data/knowledge/refresh/knowledge_area_adjustments.json
data/knowledge/knowledge_inputs_snapshot.json
