{
  "version": 2,
  "description": "Refresh dirigido: prioriza áreas débiles, observa datos nuevos sin aceptar automáticamente.",
  "max_areas_per_run": 4,
  "priority_status_order": ["weak", "developing", "usable", "strong"],
  "secondary_sort": "area_score_asc",
  "dojo_candidates_per_area": 1,
  "dojo_min_relevant_observations": 1,
  "dojo_relevant_observation_kinds": [
    "dataset_index_path_new",
    "pattern_file_changed",
    "http_allowlist_fetch"
  ],
  "allow_http_fetch": false,
  "http_allowlist": [],
  "run_extract_script": false,
  "extract_script_relative": "scripts/extract_revmax_knowledge.py",
  "quality_rules_for_acceptance": {
    "min_reason_for_acceptance_length": 12,
    "min_summary_length": 12,
    "require_area_key": true,
    "require_content_hash": true,
    "max_duplicate_hash": 1
  },
  "accepted_quality_scoring": {
    "max_quality_bonus_points": 8.0,
    "per_accept_with_link_and_type": 2.0,
    "per_accept_partial_link": 0.75,
    "per_accept_minimal": 0.35
  },
  "knowledge_balancing": {
    "enabled": true,
    "use_dynamic_area_selection": true,
    "dojo_effort_multiplier_max": 2.5,
    "max_http_slots_balanced": 1
  },
  "notes": "Selección de áreas vía knowledge_balancing_engine (gap/prioridad), no uniforme. Dojo solo si relevancia; multiplicador según gap. Métricas funnel en refresh_funnel_metrics.json."
}
